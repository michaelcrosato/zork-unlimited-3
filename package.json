{
  "name": "zork-unlimited-3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A minimal LLM-playable choose-your-own-adventure engine.",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "health": "npm run format:check && npm run lint && npm test && npm run cyoa -- validate stories/demo.yaml --json && npm run cyoa -- playtest stories/demo.yaml --runs 100 --strategy coverage --summary --json",
    "ai:cycle": "node --import tsx src/ai-loop.ts --once",
    "ai:loop": "node --import tsx src/ai-loop.ts",
    "ai:metrics": "node --import tsx src/ai-loop-observations.ts",
    "cyoa": "node --import tsx src/cli.ts",
    "mcp": "node --import tsx --input-type=module --eval \"await import('./src/mcp.ts')\"",
    "validate": "node --import tsx src/cli.ts validate stories/demo.yaml",
    "playtest": "node --import tsx src/cli.ts playtest stories/demo.yaml --runs 50",
    "playtest:session": "node --import tsx src/blind-playtester.ts",
    "playtest:consolidate": "node --import tsx src/consolidate-feedback.ts",
    "playtest:loop": "bash playtest_loop.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
